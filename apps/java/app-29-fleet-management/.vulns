  "chained_attacks": [
    {
      "chain_id": "chain-01",
      "chain_name": "Log4Shell \u2192 SSRF \u2192 Lateral Movement",
      "attack_scenario": "Attacker triggers Log4Shell injection via search parameter which gets logged via Log4j 2.14.1, gains initial execution environment access, and exploits the unvalidated SSRF endpoint to query cloud metadata (169.254.169.254) and retrieve IAM credentials.",
      "impact": "lateral_movement",
      "components": [
        {
          "step": 1,
          "owasp_id": "A06",
          "description": "Application uses Log4j 2.14.1 and logs query inputs, making it vulnerable to JNDI injection.",
