      "method": "searchRooms",
      "line_range": "20-29",
      "description": "JPQL query constructed using string concatenation with user-supplied parameters allows SQL/JPQL injection",
      "severity": "high",
      "cwe": "CWE-89"
    },
    {
      "owasp_id": "A05",
      "category": "Security Misconfiguration",
      "location": "src/main/java/com/hotel/reservation/controller/AdminController.java",
      "method": "getSystemInfo",
      "line_range": "14-25",
      "description": "Exposed admin debug endpoint without authentication leaks system variables and default admin credentials",
      "severity": "medium",
      "cwe": "CWE-215"
    },
    {
      "owasp_id": "A07",
      "category": "Identification and Authentication Failures",
      "location": "src/main/java/com/hotel/reservation/config/SecurityConfig.java",
      "method": "filterChain",
      "line_range": "31-35",
      "description": "Session fixation protection is disabled via sessionFixation().none(), meaning session IDs are not rotated upon login",
      "severity": "medium",
      "cwe": "CWE-384"
    }
  ],
