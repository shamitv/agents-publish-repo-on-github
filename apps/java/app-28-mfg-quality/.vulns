  "vulnerabilities": [
    {
      "owasp_id": "A01",
      "category": "Broken Access Control",
      "location": "src/main/java/com/manufacturing/qc/controller/AuthController.java",
      "method": "updateProfile",
      "line_range": "32-43",
      "description": "Mass assignment vulnerability on user profile update allows workers to escalate privilege to QA_MANAGER",
      "severity": "high",
      "cwe": "CWE-915"
    },
    {
      "owasp_id": "A04",
      "category": "Insecure Design",
      "location": "src/main/java/com/manufacturing/qc/controller/DefectController.java",
      "method": "resolveDefect",
      "line_range": "17-25",
      "description": "Critical defect resolution workflow lacks formal manager approval check, allowing self-resolution",
      "severity": "medium",
      "cwe": "CWE-841"
    },
    {
      "owasp_id": "A09",
      "category": "Security Logging and Monitoring Failures",
      "location": "src/main/java/com/manufacturing/qc/service/InspectionService.java",
      "method": "updateInspectionResult",
      "line_range": "21-30",
      "description": "Inspection log modifications lack audit logging, permitting silent changes to QA reports",
      "severity": "low",
      "cwe": "CWE-778"
    }
  ],
