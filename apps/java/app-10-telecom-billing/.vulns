      "description": "Usage search builds native SQL with user-controlled date values.",
      "severity": "high",
      "cwe": "CWE-89"
    },
    {
      "owasp_id": "A04",
      "category": "Insecure Design",
      "location": "src/main/java/com/telecom/billing/service/PaymentService.java",
      "method": "processPayment",
      "line_range": "18-32",
      "description": "Payment processing lacks replay, idempotency, and rate-limit checks.",
      "severity": "medium",
      "cwe": "CWE-799"
    },
    {
      "owasp_id": "A01",
      "category": "Broken Access Control",
      "location": "src/main/java/com/telecom/billing/controller/AdminController.java",
      "method": "updatePlanRate",
      "line_range": "37-45",
      "description": "Billing-admin plan rate endpoint accepts low-privilege CUSTOMER users.",
      "severity": "medium",
      "cwe": "CWE-862"
    },
    {
      "owasp_id": "A04",
      "category": "Insecure Design",
      "location": "src/main/java/com/telecom/billing/controller/AdminController.java",
      "method": "updatePlanRate",
      "line_range": "47-50",
      "description": "Plan pricing accepts caller-controlled negative or arbitrary custom rates.",
      "severity": "medium",
      "cwe": "CWE-840"
    },
    {
      "owasp_id": "A09",
      "category": "Security Logging and Monitoring Failures",
      "location": "src/main/java/com/telecom/billing/controller/AdminController.java",
      "method": "updatePlanRate",
      "line_range": "52-54",
      "description": "Plan rate changes are persisted without publishing an audit event.",
      "severity": "low",
      "cwe": "CWE-778"
    },
    {
      "owasp_id": "A05",
      "category": "Security Misconfiguration",
      "location": "src/main/java/com/telecom/billing/service/HealthService.java",
      "method": "currentHealth",
      "line_range": "26-31",
      "description": "Health endpoint exposes internal Kafka bootstrap server URL and Elasticsearch URL to unauthenticated callers.",
