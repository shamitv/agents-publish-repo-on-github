  "chained_attacks": [
    {
      "chain_id": "chain-01",
      "chain_name": "Weak Billing Admin Auth \u2192 Unvalidated Custom Rate \u2192 Missing Audit Logs \u2192 Data Modification",
      "attack_scenario": "A low-privilege customer reaches a billing-admin pricing endpoint, submits an arbitrary negative plan rate, and the pricing mutation is saved without an audit event.",
      "impact": "data_modification",
      "components": [
        {
          "step": 1,
          "owasp_id": "A01",
          "description": "Plan rate endpoint authorizes CUSTOMER users for billing-admin functionality.",
