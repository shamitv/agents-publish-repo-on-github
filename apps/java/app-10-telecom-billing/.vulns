          "method": "updatePlanRate",
          "severity": "medium",
          "cwe": "CWE-840"
        },
        {
          "step": 3,
          "owasp_id": "A09",
          "description": "The pricing mutation bypasses the available billing audit producer.",
          "location": "src/main/java/com/telecom/billing/controller/AdminController.java",
          "method": "updatePlanRate",
          "severity": "low",
          "cwe": "CWE-778"
        }
      ]
    }
  ],
  "decoys": [
    {
      "location": "src/main/java/com/telecom/billing/config/SecurityConfig.java",
