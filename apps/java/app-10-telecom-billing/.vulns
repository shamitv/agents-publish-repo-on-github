          "method": "updatePlanRate",
          "severity": "medium",
          "cwe": "CWE-862"
        },
        {
          "step": 2,
          "owasp_id": "A04",
          "description": "Caller-controlled custom rates, including negative values, are written directly to plan pricing.",
