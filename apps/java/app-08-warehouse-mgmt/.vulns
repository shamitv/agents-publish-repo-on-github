{
  "app_id": "app-08",
  "app_name": "Warehouse Management System",
  "language": "java",
  "framework": "spring-boot",
  "vulnerabilities": [
    {
      "owasp_id": "A05",
      "category": "Security Misconfiguration",
      "location": "src/main/resources/application.properties",
      "method": null,
      "line_range": "15-25",
      "description": "Spring Boot Actuator endpoints (env, heapdump, beans, mappings) exposed publicly without authentication via management.endpoints.web.exposure.include=*",
      "severity": "high",
      "cwe": "CWE-16",
      "secondary_location": "src/main/java/com/warehouse/config/SecurityConfig.java"
    },
    {
      "owasp_id": "A03",
      "category": "Injection",
      "location": "src/main/java/com/warehouse/service/EmployeeLdapService.java",
      "method": "searchEmployees",
      "line_range": "15-22",
      "description": "LDAP filter constructed via string concatenation with user-supplied search term, enabling LDAP injection to enumerate all employees or extract hidden attributes",
      "severity": "high",
      "cwe": "CWE-90"
    },
    {
      "owasp_id": "A10",
      "category": "Server-Side Request Forgery (SSRF)",
      "location": "src/main/java/com/warehouse/service/ShippingService.java",
      "method": "generateLabel",
      "line_range": "12-35",
      "description": "Shipping label URL fetched server-side via HttpURLConnection with no scheme, host, or port validation \u2014 allows access to cloud metadata, internal services, and local files",
      "severity": "critical",
      "cwe": "CWE-918"
    }
  ],
  "chained_attacks": [
    {
      "chain_id": "chain-01",
      "chain_name": "LDAP Injection \u2192 Directory Structure Disclosure \u2192 Inventory Tampering",
      "attack_scenario": "Attacker injects a malformed LDAP filter that triggers an exception; the verbose error response reveals internal DN paths and account naming conventions. The attacker authenticates with a discovered worker account and calls the unprotected inventory adjustment endpoint to zero out stock counts.",
      "impact": "data_modification",
      "components": [
        {
          "step": 1,
          "owasp_id": "A03",
          "description": "LDAP filter built by direct string concatenation of user input in searchEmployees(), enabling injection to enumerate arbitrary directory entries",
          "location": "src/main/java/com/warehouse/service/EmployeeLdapService.java",
          "method": "searchEmployees",
          "severity": "medium",
          "cwe": "CWE-90",
          "required_evidence": [
            "src/main/java/com/warehouse/service/EmployeeLdapService.java",
            "searchEmployees"
          ],
          "negative_evidence": []
        },
        {
          "step": 2,
          "owasp_id": "A05",
          "description": "LDAP exceptions including internal DN paths are returned verbatim in the HTTP 500 error body, revealing directory structure to the attacker",
          "location": "src/main/java/com/warehouse/controller/EmployeeController.java",
          "method": "search",
          "severity": "low",
          "cwe": "CWE-209",
          "required_evidence": [
            "src/main/java/com/warehouse/controller/EmployeeController.java",
            "search"
          ],
          "negative_evidence": []
        },
        {
          "step": 3,
          "owasp_id": "A01",
          "description": "POST /api/inventory/{id}/adjust requires only authentication (no role check), allowing any worker account to modify stock quantities for any item",
          "location": "src/main/java/com/warehouse/controller/InventoryController.java",
          "method": "adjustQuantity",
          "severity": "high",
          "cwe": "CWE-862",
          "required_evidence": [
            "src/main/java/com/warehouse/controller/InventoryController.java",
            "adjustQuantity"
          ],
          "negative_evidence": []
        }
      ],
      "difficulty": "medium",
