{
  "app_id": "app-07",
  "app_name": "Airline Booking System",
  "language": "java",
  "framework": "spring-boot",
  "vulnerabilities": [
    {
      "owasp_id": "A03",
      "category": "Injection",
      "location": "src/main/java/com/airline/repository/FlightSearchDao.java",
      "method": "searchFlights",
      "line_range": "18-23",
      "description": "Flight search SQL query is built via string concatenation with user-supplied origin, destination, and date values.",
      "severity": "critical",
      "cwe": "CWE-89"
    },
    {
      "owasp_id": "A07",
      "category": "Identification and Authentication Failures",
      "location": "src/main/java/com/airline/config/SecurityConfig.java",
      "method": "filterChain",
      "line_range": "50-52",
      "description": "Session fixation protection is disabled via sessionFixation().none(), so the session ID is not rotated on login.",
      "severity": "high",
      "cwe": "CWE-384"
    },
    {
      "owasp_id": "A04",
      "category": "Insecure Design",
      "location": "src/main/java/com/airline/service/BookingService.java",
      "method": "createBooking",
      "line_range": "39-73",
      "description": "Booking creation immediately reserves inventory without rate limiting, payment timeout, or concurrency controls, allowing inventory hoarding.",
      "severity": "high",
      "cwe": "CWE-799"
    }
  ],
  "chained_attacks": [
    {
      "chain_id": "chain-01",
      "chain_name": "Sequential PNR Enumeration -> Booking IDOR -> Stored XSS on Staff View",
      "attack_scenario": "Attacker registers with a script payload in their passenger name, enumerates predictable PNRs, accesses boarding summaries without ownership checks, and triggers stored XSS when airline staff render the summary in the boarding UI.",
      "impact": "account_takeover",
      "components": [
        {
          "step": 1,
          "owasp_id": "A04",
          "description": "PNRs are generated as incrementing values such as BK000001, making booking references predictable.",
          "location": "src/main/java/com/airline/service/PnrGenerator.java",
          "method": "generate",
          "line_range": "8-10",
          "severity": "low",
          "cwe": "CWE-330"
        },
        {
          "step": 2,
          "owasp_id": "A01",
          "description": "The boarding-summary endpoint returns booking details for any valid PNR without verifying the requester owns the booking.",
          "location": "src/main/java/com/airline/controller/BookingController.java",
          "method": "getBoardingSummary",
          "line_range": "70-86",
          "severity": "medium",
          "cwe": "CWE-639"
        },
        {
          "step": 3,
          "owasp_id": "A03",
          "description": "Passenger name is returned as raw HTML and rendered with innerHTML in the staff boarding UI.",
          "location": "src/main/java/com/airline/controller/BookingController.java",
          "secondary_location": "src/main/resources/templates/staff-boarding.html",
          "method": "getBoardingSummary",
          "line_range": "80-82",
          "severity": "medium",
          "cwe": "CWE-79"
        }
      ],
      "difficulty": "medium",
      "subtlety_tags": [
        "cross_file",
        "direct_data_flow",
        "realistic_decoy"
      ],
      "chain_prerequisites": [
        "attacker has or can create a passenger account",
        "attacker can create a booking with a controlled passenger name",
        "airline staff can load boarding summaries in the staff UI"
      ],
      "negative_evidence": [
        "src/main/java/com/airline/controller/BookingController.java",
        "getByPnr",
        "src/main/java/com/airline/support/ReferenceGuards.java",
        "ReferenceGuards.sameOwner"
      ],
      "vulnerability_family": "idor",
      "required_evidence": [
        "src/main/java/com/airline/service/PnrGenerator.java",
        "generate",
        "src/main/java/com/airline/controller/BookingController.java",
        "getBoardingSummary",
        "src/main/resources/templates/staff-boarding.html",
        "innerHTML"
      ]
    },
    {
      "chain_id": "chain-02",
      "chain_name": "Predictable Seat Hold References -> Hold Ownership Bypass -> Unauthorized Hold Confirmation",
      "attack_scenario": "Attacker guesses another passenger's predictable hold reference, reads or changes the held seat without ownership validation, and confirms the hold as their own booking without owner or payment verification.",
      "impact": "data_modification",
      "components": [
        {
          "step": 1,
          "owasp_id": "A04",
          "description": "Seat hold references use predictable incrementing values such as HOLD000101.",
          "location": "src/main/java/com/airline/service/HoldRefGenerator.java",
          "method": "generate",
          "line_range": "10-12",
          "severity": "low",
          "cwe": "CWE-330"
        },
        {
          "step": 2,
          "owasp_id": "A01",
          "description": "Hold read and seat-change operations trust holdRef and skip owner validation.",
          "location": "src/main/java/com/airline/service/SeatHoldService.java",
          "method": "getHoldByRef/changeHeldSeat",
          "line_range": "78-111",
          "severity": "medium",
          "cwe": "CWE-639"
        },
        {
          "step": 3,
          "owasp_id": "A04",
          "description": "Hold confirmation trusts holdRef and skips owner and payment-state verification before creating a confirmed booking.",
          "location": "src/main/java/com/airline/service/SeatHoldService.java",
          "method": "confirmHold",
          "line_range": "115-137",
          "severity": "medium",
          "cwe": "CWE-345"
        }
      ],
      "difficulty": "medium",
      "subtlety_tags": [
        "stateful_flow",
        "implicit_trust",
        "realistic_decoy"
      ],
      "chain_prerequisites": [
        "attacker has or can create a passenger account",
        "another passenger has an active seat hold",
        "attacker can guess or enumerate nearby hold references"
      ],
      "negative_evidence": [
        "src/main/java/com/airline/service/SeatHoldService.java",
        "getOwnedHold",
        "src/main/java/com/airline/support/ReferenceGuards.java",
        "ReferenceGuards.sameOwner"
      ],
      "vulnerability_family": "idor",
      "required_evidence": [
        "src/main/java/com/airline/service/HoldRefGenerator.java",
        "generate",
        "src/main/java/com/airline/service/SeatHoldService.java",
        "getHoldByRef",
        "changeHeldSeat",
        "confirmHold"
      ]
    }
  ],
  "decoys": [
    {
      "location": "src/main/java/com/airline/config/SecurityConfig.java",
      "description": "BCryptPasswordEncoder hashes passwords and is safe."
    },
    {
      "location": "src/main/java/com/airline/repository/FlightRepository.java",
      "description": "Spring Data JPA repository methods do not concatenate SQL."
    },
    {
      "location": "src/main/java/com/airline/controller/BookingController.java",
      "description": "GET /api/bookings/{pnr} validates booking ownership before returning details."
    },
    {
      "location": "src/main/java/com/airline/service/SeatHoldService.java",
      "description": "getOwnedHold verifies hold ownership and is a safe decoy near vulnerable hold operations."
    }
  ],
  "benchmark_profile": {
    "version": "v1.0",
    "target_difficulty": "medium",
    "upgrade_style": "complex airline rewrite with two contextual chains",
    "decoy_file": "src/main/java/com/airline/support/ReferenceGuards.java"
  }
}
