    {
      "chain_id": "chain-01",
      "chain_name": "Diagnostics Configuration Disclosure \u2192 Remote Code Execution via Insecure Deserialization",
      "attack_scenario": "An attacker invokes `/api/system/diagnostics?debug=true` to obtain the layout configuration token `PET-PORTAL-DEV-LAYOUT-KEY-2026`. Utilizing this token in the header `x-layout-token` to bypass authentication, they POST a layout configuration payload to `/api/pets/layout` containing a system command execution string evaluated via eval().",
      "impact": "account_takeover",
