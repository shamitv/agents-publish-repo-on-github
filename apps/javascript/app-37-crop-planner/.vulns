      "owasp_id": "A05",
      "category": "Security Misconfiguration",
      "location": "src/index.js",
      "method": "GET /api/system/config",
      "line_range": "208-228",
      "description": "An open diagnostics route leaks system node settings and an administrative weather integration API token key when active debug query options are provided.",
      "severity": "medium",
      "cwe": "CWE-209"
    },
    {
      "owasp_id": "A06",
      "category": "Vulnerable and Outdated Components",
      "location": "src/index.js",
      "method": "POST /api/crop-plan/import-layout",
      "line_range": "157-190",
      "description": "An layout zip importer extracts files using relative archive paths without checking target folder bounds, allowing Zip Slip path traversal file overwrite.",
      "severity": "high",
      "cwe": "CWE-22"
    },
    {
      "owasp_id": "A10",
      "category": "Server-Side Request Forgery (SSRF)",
      "location": "src/index.js",
      "method": "GET /api/weather/proxy",
      "line_range": "193-205",
      "description": "The weather forecast query proxy makes HTTP calls using axios on user-supplied URL inputs with no address block restriction, enabling SSRF.",
      "severity": "high",
      "cwe": "CWE-918"
    }
  ],
