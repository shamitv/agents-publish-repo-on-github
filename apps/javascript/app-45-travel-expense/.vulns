          "method": "POST /api/auth/login",
          "severity": "medium",
          "cwe": "CWE-328",
          "required_evidence": [
            "src/index.js",
            "POST /api/auth/login"
          ],
          "negative_evidence": []
        }
      ],
      "difficulty": "expert",
      "subtlety_tags": [
