      "location": "src/index.js",
      "method": "GET /api/guestbook",
      "line_range": "155-165",
      "description": "Visitor guestbook comments are rendered to the client without HTML entity encoding, leaving visitors vulnerable to Stored XSS.",
      "severity": "high",
      "cwe": "CWE-79"
