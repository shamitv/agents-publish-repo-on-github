{
  "app_id": "app-39",
  "app_name": "Wedding Planning Platform",
  "language": "javascript",
  "framework": "express",
  "vulnerabilities": [
    {
      "owasp_id": "A01",
      "category": "Broken Access Control",
      "location": "src/index.js",
      "method": "GET /api/events/:id/guests",
      "line_range": "164-175",
      "description": "Viewing event guest lists by event ID lacks verification of user ownership, allowing any authenticated planner to view contact details of other event attendees.",
      "severity": "medium",
      "cwe": "CWE-639"
    },
    {
      "owasp_id": "A02",
      "category": "Cryptographic Failures",
      "location": "src/index.js",
      "method": "POST /api/auth/login",
      "line_range": "116-136",
      "description": "User account passwords are encrypted using unsalted MD5 hashing and saved in the database, allowing brute-force or rainbow table cracking.",
      "severity": "medium",
      "cwe": "CWE-328"
    },
    {
      "owasp_id": "A07",
      "category": "Identification and Authentication Failures",
      "location": "src/index.js",
      "method": "POST /api/auth/login",
      "line_range": "116-136",
      "description": "Session identifiers are created using predictable Math.random() values instead of secure PRNG tokens.",
      "severity": "medium",
      "cwe": "CWE-330"
    }
  ],
  "chained_attacks": [
    {
      "chain_id": "chain-01",
      "chain_name": "Predictable Session Hijacking → IDOR Guest List Harvesting",
      "attack_scenario": "An attacker guesses active session keys generated by Math.random() belonging to a wedding coordinator, sets the session cookie in their browser, and calls `/api/events/2/guests` to retrieve guest lists (including names and emails) of other users via IDOR.",
      "impact": "db_exfiltration",
      "components": [
        {
          "step": 1,
          "owasp_id": "A07",
          "description": "Weak session token generation via predictable random number generator.",
          "location": "src/index.js",
          "method": "POST /api/auth/login",
          "severity": "medium",
          "cwe": "CWE-330"
        },
        {
          "step": 2,
          "owasp_id": "A01",
          "description": "Guests endpoint is vulnerable to IDOR fetching.",
          "location": "src/index.js",
          "method": "GET /api/events/:id/guests",
          "severity": "medium",
          "cwe": "CWE-639"
        }
      ]
    }
  ],
  "decoys": [
    {
      "location": "src/index.js",
      "description": "Proper user scoping constraints in GET /api/events limiting output database entries to active planners only."
    },
    {
      "location": "src/index.js",
      "description": "Proper parameterized query logic in GET /api/events/:id to fetch event details safely."
    }
  ]
}
