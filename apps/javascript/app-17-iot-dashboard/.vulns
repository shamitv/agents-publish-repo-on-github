  "chained_attacks": [
    {
      "chain_id": "chain-01",
      "chain_name": "Debug Config Leak \u2192 HTTP SSRF \u2192 Plaintext Device Token Exposure \u2192 Lateral Movement",
      "attack_scenario": "An authenticated user triggers a command error that leaks the internal telemetry URL and token, then uses the refresh SSRF endpoint to call telemetry and retrieve plaintext device tokens.",
