{
  "app_id": "app-17",
  "app_name": "IoT Device Dashboard",
  "language": "javascript",
  "framework": "express",
  "vulnerabilities": [
    {
      "owasp_id": "A05",
      "category": "Security Misconfiguration",
      "location": "src/services/DeviceService.js",
      "method": "commandError",
      "line_range": "25-36",
      "description": "Verbose command errors return stack traces plus internal telemetry URL and access token.",
      "severity": "medium",
      "cwe": "CWE-209"
    },
    {
      "owasp_id": "A10",
      "category": "Server-Side Request Forgery",
      "location": "src/services/RefreshService.js",
      "method": "refreshStatus",
      "line_range": "4-8",
      "description": "Device refresh fetches caller-controlled status URLs with axios and no internal network restrictions.",
      "severity": "medium",
      "cwe": "CWE-918"
    },
    {
      "owasp_id": "A02",
      "category": "Cryptographic Failures",
      "location": "src/db/InMemoryStore.js",
      "method": "constructor",
      "line_range": "10-14",
      "description": "Device access tokens are stored as plaintext fields.",
      "severity": "medium",
      "cwe": "CWE-312"
    },
    {
      "owasp_id": "A02",
      "category": "Cryptographic Failures",
      "location": "src/services/TelemetryService.js",
      "method": "internalTelemetry",
      "line_range": "7-17",
      "description": "Internal telemetry returns plaintext device tokens once the leaked telemetry token is supplied.",
      "severity": "medium",
      "cwe": "CWE-312"
    },
    {
      "owasp_id": "A03",
      "category": "Injection",
      "location": "src/repositories/TelemetryRepository.js",
      "method": "queryWithFilter",
      "line_range": "23-27",
      "description": "Raw SQL filter string concatenated into telemetry SELECT query allowing SQL injection.",
      "severity": "medium",
      "cwe": "CWE-89"
    },
    {
      "owasp_id": "A01",
      "category": "Broken Access Control",
      "location": "src/controllers/DeviceController.js",
      "method": "getDeviceTelemetry",
      "line_range": "56-64",
      "description": "Device telemetry endpoint returns telemetry data for any device without verifying user ownership.",
      "severity": "medium",
      "cwe": "CWE-639"
    }
  ],
  "chained_attacks": [
    {
      "chain_id": "chain-01",
      "chain_name": "Debug Config Leak \u2192 HTTP SSRF \u2192 Plaintext Device Token Exposure \u2192 Lateral Movement",
      "attack_scenario": "An authenticated user triggers a command error that leaks the internal telemetry URL and token, then uses the refresh SSRF endpoint to call telemetry and retrieve plaintext device tokens.",
      "impact": "lateral_movement",
      "components": [
        {
          "step": 1,
          "owasp_id": "A05",
          "description": "Command failure response leaks internal telemetry URL and access token.",
          "location": "src/services/DeviceService.js",
          "method": "commandError",
          "severity": "medium",
          "cwe": "CWE-209"
        },
        {
          "step": 2,
          "owasp_id": "A10",
          "description": "Device refresh fetches the attacker-supplied internal telemetry URL server-side.",
          "location": "src/services/RefreshService.js",
          "method": "refreshStatus",
          "severity": "medium",
          "cwe": "CWE-918"
        },
        {
          "step": 3,
          "owasp_id": "A02",
          "description": "Internal telemetry returns device records with plaintext device tokens.",
          "location": "src/services/TelemetryService.js",
          "method": "internalTelemetry",
          "severity": "medium",
          "cwe": "CWE-312"
        }
      ]
    },
    {
      "chain_id": "chain-02",
      "chain_name": "IDOR Telemetry Access \u2192 SQL Injection \u2192 Database Exfiltration",
      "attack_scenario": "An authenticated user exploits IDOR on GET /api/devices/:id/telemetry to read any device's telemetry, then injects SQL via the POST /api/devices/:id/telemetry/query filter parameter to UNION SELECT from the users table, dumping password hashes and device secrets.",
      "impact": "db_exfiltration",
      "components": [
        {
          "step": 1,
          "owasp_id": "A01",
          "description": "Device telemetry endpoint returns telemetry for any device ID without verifying the requesting user's ownership.",
          "location": "src/controllers/DeviceController.js",
          "method": "getDeviceTelemetry",
          "severity": "medium",
          "cwe": "CWE-639"
        },
        {
          "step": 2,
          "owasp_id": "A03",
          "description": "Telemetry query filter parameter is concatenated into raw SQL, enabling UNION SELECT injection against users/devices tables.",
          "location": "src/repositories/TelemetryRepository.js",
          "method": "queryWithFilter",
          "severity": "medium",
          "cwe": "CWE-89"
        }
      ]
    }
  ],
  "decoys": [
    {
      "location": "src/controllers/DeviceController.js",
      "description": "Device command payload validates command type and length before execution."
    },
    {
      "location": "src/services/DeviceService.js",
      "description": "Public device detail response omits the deviceSecret field."
    },
    {
      "location": "src/referenceGuards.js",
      "description": "Reference callback allowlist guard demonstrates safe URL validation."
    },
    {
      "location": "src/services/TelemetryQueryService.js",
      "description": "getDeviceTelemetryRange() uses parameterized queries for timestamp range filtering."
    },
    {
      "location": "src/controllers/DeviceController.js -> detail()",
      "description": "Public device detail returns device info by ID but strips deviceSecret field."
    },
    {
      "location": "src/repositories/PgUserRepository.js",
      "description": "User passwords are hashed with bcrypt before storage."
    }
  ]
}
