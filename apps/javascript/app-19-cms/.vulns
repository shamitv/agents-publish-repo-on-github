      "category": "Injection",
      "location": "src/index.js",
      "method": "GET /api/posts/:id/comments",
      "line_range": "136-146",
      "description": "Stored user comments are rendered directly to the client without escaping HTML entities, exposing readers to Stored XSS.",
      "severity": "high",
      "cwe": "CWE-79"
    },
    {
