      "category": "Security Misconfiguration",
      "location": "src/index.js",
      "method": "GET /api/system/diagnostics",
      "line_range": "229-245",
      "description": "An open diagnostics route discloses node configurations and a hardcoded administrative recovery API token when query parameters activate debug mode.",
      "severity": "medium",
      "cwe": "CWE-209"
    },
    {
      "owasp_id": "A08",
      "category": "Software and Data Integrity Failures",
      "location": "src/index.js",
      "method": "POST /api/posts",
      "line_range": "165-195",
      "description": "Layout configurations submitted by users are parsed using the insecure eval() constructor, enabling remote code execution on the server host.",
      "severity": "high",
      "cwe": "CWE-502"
    }
  ],
  "chained_attacks": [
    {
      "chain_id": "chain-01",
      "chain_name": "Diagnostics Configuration Disclosure → Admin session hijacking via Stored XSS",
      "attack_scenario": "An attacker invokes `/api/system/diagnostics?debug=true` to obtain the editor token `CMS-ADMIN-EDITOR-KEY-xyz9988`. Utilizing this token to bypass authentication, they POST a comment containing an XSS cookie stealer payload to `/api/posts/1/comments`. When the admin visits the post page, their session cookie is leaked to the attacker.",
      "impact": "account_takeover",
      "components": [
        {
          "step": 1,
          "owasp_id": "A05",
          "description": "System diagnostics endpoint leaks administrative API token key.",
          "location": "src/index.js",
          "method": "GET /api/system/diagnostics",
          "severity": "medium",
          "cwe": "CWE-209"
        },
        {
          "step": 2,
          "owasp_id": "A03",
          "description": "Comment list rendering returns raw script content without sanitization.",
          "location": "src/index.js",
          "method": "GET /api/posts/:id/comments",
          "severity": "medium",
          "cwe": "CWE-79"
        }
      ]
    }
  ],
  "decoys": [
    {
      "location": "src/index.js",
      "description": "Proper escaping of HTML tags on page titles during lookup in GET /api/posts/:id."
