  "chained_attacks": [
    {
      "chain_id": "chain-01",
      "chain_name": "Book Search SQLi \u2192 Unsalted MD5 librarian account cracking",
      "attack_scenario": "An attacker uses SQL Injection on the search endpoint `/api/books/search?q=1984' UNION SELECT 1,username,password_hash,role FROM users --` to dump the users table. They retrieve the unsalted MD5 hash `db59fe16fcdcc4e70e3047d9539f37c3` for the admin_librarian user. By performing offline MD5 decryption/lookup, they crack the admin password ('librarianSecure2026!') and take over the admin session, using it to exfiltrate private reader reservation details via IDOR.",
      "impact": "account_takeover",
      "components": [
        {
          "step": 1,
          "owasp_id": "A03",
          "description": "Union-based SQL injection on book search exposes internal database tables.",
          "location": "src/index.js",
          "method": "GET /api/books/search",
          "severity": "medium",
          "cwe": "CWE-89",
