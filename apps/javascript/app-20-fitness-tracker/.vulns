{
  "app_id": "app-20",
  "app_name": "Fitness Tracking API",
  "language": "javascript",
  "framework": "express",
  "vulnerabilities": [
    {
      "owasp_id": "A01",
      "category": "Broken Access Control",
      "location": "src/index.js",
      "method": "GET /api/activities/:id",
      "line_range": "139-155",
      "description": "Viewing activity logs by ID lacks user ownership validation, allowing any authenticated runner to retrieve another customer's private fitness details.",
      "severity": "medium",
      "cwe": "CWE-639"
    },
    {
      "owasp_id": "A06",
      "category": "Vulnerable and Outdated Components",
      "location": "src/index.js",
      "method": "unsafeMerge",
      "line_range": "157-170",
      "description": "An insecure recursive object merger helper fails to check for prototype properties, exposing the application to prototype pollution.",
      "severity": "medium",
      "cwe": "CWE-1321"
    },
    {
      "owasp_id": "A07",
      "category": "Identification and Authentication Failures",
      "location": "src/index.js",
      "method": "POST /api/auth/login",
      "line_range": "96-112",
      "description": "Session identifiers are created using predictable Math.random() values instead of secure PRNG tokens.",
      "severity": "medium",
      "cwe": "CWE-330"
    }
  ],
  "chained_attacks": [
    {
      "chain_id": "chain-01",
      "chain_name": "Predictable Session Hijacking → IDOR Fitness Log Theft",
      "attack_scenario": "An attacker guesses active session keys generated by Math.random(), sets the session cookie in their browser, and calls `/api/activities/1` to view private fitness workouts of other users, achieving database exfiltration.",
      "impact": "db_exfiltration",
      "components": [
        {
          "step": 1,
          "owasp_id": "A07",
          "description": "Weak session token generation via predictable random number generator.",
          "location": "src/index.js",
          "method": "POST /api/auth/login",
          "severity": "medium",
          "cwe": "CWE-330"
        },
        {
          "step": 2,
          "owasp_id": "A01",
          "description": "Activities endpoint is vulnerable to IDOR fetching.",
          "location": "src/index.js",
          "method": "GET /api/activities/:id",
          "severity": "medium",
          "cwe": "CWE-639"
        }
      ]
    }
  ],
  "decoys": [
    {
      "location": "src/index.js",
      "description": "Proper Bcrypt hashing for password storage and validation."
    },
    {
      "location": "src/index.js",
      "description": "Proper owner isolation in GET /api/activities scoping selection to active user's ID only."
    }
  ]
