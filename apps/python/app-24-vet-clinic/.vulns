{
  "app_id": "app-24",
  "app_name": "Veterinary Clinic Management",
  "language": "python",
  "framework": "fastapi",
  "vulnerabilities": [
    {
      "owasp_id": "A02",
      "category": "Cryptographic Failures",
      "location": "app.py",
      "method": "generate_token",
      "line_range": "16-19",
      "description": "JWT authentication tokens are signed with a weak, hardcoded secret ('secret123') using HS256, allowing an attacker to forge arbitrary tokens (such as possessing a VET or ADMIN role).",
      "severity": "high",
      "cwe": "CWE-327"
    },
    {
      "owasp_id": "A03",
      "category": "Injection",
      "location": "app.py",
      "method": "search_pets",
      "line_range": "174-191",
      "description": "The pet search endpoint concatenates user input directly into a raw SQL query, allowing SQL injection to bypass role checks or leak DB records.",
      "severity": "high",
      "cwe": "CWE-89"
    },
    {
      "owasp_id": "A09",
      "category": "Security Logging & Monitoring Failures",
      "location": "app.py",
      "method": "update_prescription",
      "line_range": "206-226",
      "description": "Modifications to drug prescriptions (such as controlled substances like Ketamine) produce no audit logs or monitoring warnings, permitting undetected dosage alteration.",
      "severity": "medium",
      "cwe": "CWE-778"
    }
  ],
