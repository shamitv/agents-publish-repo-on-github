{
  "app_id": "app-01",
  "app_name": "E-Commerce Product Catalog API",
  "language": "python",
  "framework": "flask",
  "vulnerabilities": [
    {
      "owasp_id": "A01",
      "category": "Broken Access Control",
      "location": "services/catalog-service/src/controllers/order_controller.py",
      "method": "get_order_details",
      "description": "Order retrieval returns any order by path ID after authentication without checking whether the requester owns the order.",
      "severity": "high",
      "cwe": "CWE-639"
    },
    {
      "owasp_id": "A03",
      "category": "Injection",
      "location": "services/catalog-service/src/services/search_service.py",
      "method": "search",
      "description": "Product search inserts user input directly into SQL fallback search and Elasticsearch query_string syntax.",
      "severity": "high",
      "cwe": "CWE-943"
    },
    {
      "owasp_id": "A09",
      "category": "Security Logging and Monitoring Failures",
      "location": "services/catalog-service/src/consumers/billing_consumer.py",
      "method": "process_order_event",
      "description": "Billing event processing changes invoice state without structured audit logging.",
      "severity": "medium",
      "cwe": "CWE-778"
    },
    {
      "owasp_id": "A04",
      "category": "Insecure Design",
      "location": "packages/domain/validators.py",
      "method": "validate_supplier_id",
      "description": "Supplier ID validation accepts zero, negative, and non-numeric values, enabling forged supplier identity injection.",
      "severity": "medium",
      "cwe": "CWE-602"
    },
    {
      "owasp_id": "A07",
      "category": "Identification and Authentication Failures",
      "location": "services/supplier-portal-api/src/services/auth_service.py",
      "method": "login",
      "description": "Supplier portal login accepts any password for any known supplier ID with no credential verification.",
      "severity": "medium",
      "cwe": "CWE-287"
    }
  ],
  "chained_attacks": [
    {
      "chain_id": "chain-01",
      "chain_name": "User Enumeration -> Session Forgery -> Catalog Modification",
      "attack_scenario": "An attacker confirms the admin username through an unauthenticated existence endpoint, uses the hardcoded Flask signing secret to forge an admin session cookie, and writes attacker-controlled product data through an admin endpoint that trusts the session role.",
      "impact": "data_modification",
      "components": [
        {
          "step": 1,
          "owasp_id": "A01",
          "description": "Unauthenticated username existence endpoint confirms privileged account names.",
          "location": "services/catalog-service/src/controllers/user_controller.py",
          "method": "user_exists",
          "severity": "low",
          "cwe": "CWE-203"
        },
        {
          "step": 2,
          "owasp_id": "A02",
          "description": "Hardcoded Flask signing secret allows forged admin session cookies.",
          "location": "services/catalog-service/src/config/settings.py",
          "method": "SECRET_KEY",
          "severity": "medium",
          "cwe": "CWE-798"
        },
        {
          "step": 3,
          "owasp_id": "A01",
          "description": "Admin product mutation endpoint trusts the forgeable session role.",
          "location": "services/catalog-service/src/controllers/product_controller.py",
          "method": "create_product",
          "severity": "medium",
          "cwe": "CWE-862"
        }
      ]
    },
    {
      "chain_id": "chain-02",
      "chain_name": "Weak Supplier ID Validation -> Catalog Poisoning via Bulk Upload",
      "attack_scenario": "An attacker exploits weak supplier ID validation to inject forged supplier IDs into bulk catalog uploads, bypassing ownership checks. Step 1: weak validator accepts any supplier ID. Step 2: bulk CSV upload trusts supplierId from request body without verifying the authenticated supplier owns that ID.",
      "impact": "data_modification",
      "components": [
        {
          "step": 1,
          "owasp_id": "A04",
          "description": "Supplier ID validator accepts zero, negative, and non-numeric values without error.",
          "location": "packages/domain/validators.py",
          "method": "validate_supplier_id_chain",
          "severity": "low",
          "cwe": "CWE-602"
        },
        {
          "step": 2,
          "owasp_id": "A01",
          "description": "Bulk CSV upload trusts supplierId from request body without ownership verification.",
          "location": "services/catalog-service/src/controllers/bulk_upload_controller.py",
          "method": "bulk_upload_products",
          "severity": "medium",
          "cwe": "CWE-639"
        }
      ]
    }
  ],
  "decoys": [
    {
      "location": "services/catalog-service/src/repositories/user_repository.py",
      "description": "Login uses parameterized SQL despite the nearby vulnerable product search flow."
    },
    {
      "location": "services/catalog-service/src/controllers/user_controller.py",
      "description": "The profile endpoint reads the authenticated session user ID rather than accepting arbitrary user IDs."
    },
    {
      "location": "packages/domain/validators.py",
      "description": "validate_date_range uses strict fromisoformat parsing and start-before-end check, co-located with the vulnerable validate_supplier_id."
    },
    {
      "location": "packages/utils/pagination.py",
      "description": "parse_pagination clamps page >= 1 and limit in [1, 100], preventing integer abuse."
    },
    {
      "location": "services/catalog-service/src/controllers/product_controller.py",
      "description": "get_my_products scopes results to authenticated supplier_id from session, co-located with vulnerable bulk upload."
    },
    {
      "location": "services/supplier-portal-api/src/services/auth_service.py",
      "description": "verify_token performs HMAC session verification, co-located with the vulnerable login that accepts any password."
    },
    {
      "location": "services/reporting-service/src/services/aggregation_service.py",
      "description": "build_sales_filters uses parameterized SQL placeholders, adjacent to the aggregation functions."
    }
  ]
}
