{
  "app_id": "app-02",
  "app_name": "Healthcare Patient Portal",
  "language": "python",
  "framework": "django",
  "vulnerabilities": [
    {
      "owasp_id": "A01",
      "category": "Broken Access Control",
      "location": "portal/views.py",
      "method": "get_patient_records",
      "line_range": "110-125",
      "description": "Patient records detail view retrieves and returns sensitive medical histories based purely on the patient_id path parameter, with no validation verifying if the authenticated user's profile ID matches the requested parameter",
      "severity": "high",
      "cwe": "CWE-639"
    },
    {
      "owasp_id": "A02",
      "category": "Cryptographic Failures",
      "location": "portal/models.py",
      "method": "set_password_md5",
      "line_range": "35-50",
      "description": "User profiles database utilizes insecure, weak MD5 hashing algorithms to store patient credentials instead of standard PBKDF2/Argon2 algorithms, exposing credentials to simple dictionary attacks",
      "severity": "high",
      "cwe": "CWE-916"
    },
    {
      "owasp_id": "A07",
      "category": "Identification & Authentication Failures",
      "location": "portal/views.py",
      "method": "login_view",
      "line_range": "70-90",
      "description": "System access authentication handles arbitrary sequential log-in retries without implementing account lockouts, rate limiting, or connection throttling rules, facilitating dictionary and brute force attacks",
      "severity": "medium",
      "cwe": "CWE-307"
    }
  ],
  "chained_attacks": [
    {
      "chain_id": "chain-01",
      "chain_name": "User Enumeration \u2192 Offline MD5 Crack \u2192 Medical Records Exfiltration",
      "attack_scenario": "Attacker enumerates valid patient usernames via distinct login error messages, cracks the unsalted MD5 password hash offline, authenticates, uses the patient search endpoint to collect all patient IDs, then dumps every patient's medical records via the IDOR endpoint.",
      "impact": "db_exfiltration",
      "components": [
        {
          "step": 1,
          "owasp_id": "A07",
          "description": "Login endpoint returns distinct error messages for unknown username vs wrong password, enabling username enumeration",
          "location": "portal/views.py",
          "method": "login_view",
          "severity": "low",
          "cwe": "CWE-204"
        },
        {
          "step": 2,
          "owasp_id": "A02",
          "description": "Passwords stored as unsalted MD5 hashes, crackable offline via rainbow tables or GPU brute force",
          "location": "portal/models.py",
          "method": "set_password_md5",
          "severity": "high",
          "cwe": "CWE-916"
        },
        {
          "step": 3,
          "owasp_id": "A01",
          "description": "Patient search endpoint returns IDs for all patients regardless of the authenticated user's own identity, enabling mass IDOR enumeration",
          "location": "portal/views.py",
          "method": "search_patients",
          "severity": "low",
          "cwe": "CWE-639"
        }
      ]
    }
  ],
  "decoys": [
    {
      "location": "patient_portal/settings.py",
      "description": "Django secure session cookie flags (SESSION_COOKIE_HTTPONLY=True, SECURE_BROWSER_XSS_FILTER=True) properly enabled — secure auth decoy"
    },
    {
      "location": "portal/views.py",
      "description": "Safe, CSRF exempt and parameterized input sanitization during appointment booking checks — secure input decoy"
    }
  ]
}
