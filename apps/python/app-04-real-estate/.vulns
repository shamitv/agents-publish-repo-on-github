{
  "app_id": "app-04",
  "app_name": "Real Estate Listing Platform",
  "language": "python",
  "framework": "flask",
  "vulnerabilities": [
    {
      "owasp_id": "A03",
      "category": "Injection",
      "location": "app.py",
      "method": "process_image_metadata",
      "line_range": "130-155",
      "description": "OS Command Injection. The image analyzer tool uses subprocess.Popen with shell=True to execute a command containing an unvalidated property file path or image metadata name, permitting arbitrary shell execution",
      "severity": "high",
      "cwe": "CWE-78"
    },
    {
      "owasp_id": "A05",
      "category": "Security Misconfiguration",
      "location": "app.py",
      "method": "app_config",
      "line_range": "12-25",
      "description": "Security Misconfiguration. Flask debug mode is explicitly set to True in production run configs, and it utilizes a default widely known secret key (secret_key=dev), permitting session tampering and remote debugger access",
      "severity": "medium",
      "cwe": "CWE-1188"
    },
    {
      "owasp_id": "A10",
      "category": "Server-Side Request Forgery",
      "location": "app.py",
      "method": "import_external_image",
      "line_range": "165-190",
      "description": "Server-Side Request Forgery (SSRF). The remote image import endpoint fetches image resources from user-provided URLs using requests.get without validating, restricting, or sanitizing internal local network IPs",
      "severity": "high",
      "cwe": "CWE-918"
    }
  ],
  "chained_attacks": [
    {
      "chain_id": "chain-01",
      "chain_name": "Debug Environment Exposure \u2192 SSRF Internal Recon \u2192 OS Command Injection RCE",
      "attack_scenario": "Attacker reads internal environment variables via the exposed debug endpoint to discover service topology, then uses SSRF to probe internal endpoints and gather further context, then injects shell commands into the analyze endpoint to achieve RCE and exfiltrate data.",
      "impact": "lateral_movement",
      "components": [
        {
          "step": 1,
          "owasp_id": "A05",
          "description": "GET /api/debug/env returns full process environment variables and working directory without authentication",
          "location": "app.py",
          "method": "debug_env",
          "severity": "low",
          "cwe": "CWE-215"
        },
        {
          "step": 2,
          "owasp_id": "A10",
          "description": "SSRF endpoint fetches arbitrary URLs with no IP-space restriction, enabling internal network mapping",
          "location": "app.py",
          "method": "import_external_image",
          "severity": "high",
          "cwe": "CWE-918"
        },
        {
          "step": 3,
          "owasp_id": "A03",
          "description": "OS command injection via shell=True subprocess with user-controlled filename — executes arbitrary system commands",
          "location": "app.py",
          "method": "analyze_listing",
          "severity": "high",
          "cwe": "CWE-78"
        }
      ]
    }
  ],
  "decoys": [
    {
      "location": "app.py",
      "description": "Standard session authorization check before uploading property directories — secure auth decoy"
    },
    {
      "location": "app.py",
      "description": "Decoy secure parameterized SQL queries for standard listing searches — secure search decoy"
    }
  ]
}
