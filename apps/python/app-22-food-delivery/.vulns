{
  "app_id": "app-22",
  "app_name": "Food Delivery Order System",
  "language": "python",
  "framework": "fastapi",
  "vulnerabilities": [
    {
      "owasp_id": "A02",
      "category": "Cryptographic Failures",
      "location": "app.py",
      "method": "PAYMENT_SECRET",
      "line_range": "9-11",
      "description": "Payment processing API key is hardcoded as a module-level constant in the source code.",
      "severity": "medium",
      "cwe": "CWE-798"
    },
    {
      "owasp_id": "A04",
      "category": "Insecure Design",
      "location": "app.py",
      "method": "place_order",
      "line_range": "136-160",
      "description": "No rate limiting or idempotency checks on order placement, allowing clients to send infinite duplicate order requests, leading to resource exhaustion or denial of service.",
      "severity": "medium",
      "cwe": "CWE-307"
    },
    {
      "owasp_id": "A07",
      "category": "Identification and Authentication Failures",
      "location": "app.py",
      "method": "login",
      "line_range": "122-127",
      "description": "Session cookie is set without the HttpOnly or Secure flags, making it vulnerable to extraction via Cross-Site Scripting (XSS).",
      "severity": "medium",
      "cwe": "CWE-1004"
    }
  ],
  "chained_attacks": [
    {
      "chain_id": "chain-01",
      "chain_name": "Hardcoded Secret Key → Webhook Forgery → Free Orders",
      "attack_scenario": "An attacker extracts the hardcoded PAYMENT_SECRET from the source code. They then call the payment webhook endpoint directly, providing this secret as the auth token, to mark their pending orders as paid without completing actual payment.",
      "impact": "data_modification",
      "components": [
        {
          "step": 1,
          "owasp_id": "A02",
          "description": "Payment secret is hardcoded in the source code.",
          "location": "app.py",
          "method": "PAYMENT_SECRET",
          "severity": "medium",
          "cwe": "CWE-798"
        },
        {
          "step": 2,
          "owasp_id": "A04",
          "description": "Payment webhook verifies authority by checking the hardcoded PAYMENT_SECRET without checking signature or request origin.",
          "location": "app.py",
          "method": "payment_webhook",
          "severity": "medium",
          "cwe": "CWE-347"
        }
      ]
    }
  ],
  "decoys": [
    {
      "location": "app.py",
      "description": "Proper Bcrypt hashing for password storage during registration and verification during login."
    },
    {
      "location": "app.py",
      "description": "Proper parameterized SQL query for listing menu items by category."
    }
  ]
