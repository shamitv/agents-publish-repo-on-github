  "vulnerabilities": [
    {
      "owasp_id": "A02",
      "category": "Cryptographic Failures",
      "location": "app.py",
      "method": "PAYMENT_SECRET",
      "line_range": "9-11",
      "description": "Payment processing API key is hardcoded as a module-level constant in the source code.",
      "severity": "medium",
      "cwe": "CWE-798"
    },
    {
      "owasp_id": "A04",
      "category": "Insecure Design",
      "location": "app.py",
      "method": "place_order",
      "line_range": "136-160",
      "description": "No rate limiting or idempotency checks on order placement, allowing clients to send infinite duplicate order requests, leading to resource exhaustion or denial of service.",
      "severity": "medium",
      "cwe": "CWE-307"
    },
    {
      "owasp_id": "A07",
      "category": "Identification and Authentication Failures",
      "location": "app.py",
      "method": "login",
      "line_range": "122-127",
      "description": "Session cookie is set without the HttpOnly or Secure flags, making it vulnerable to extraction via Cross-Site Scripting (XSS).",
      "severity": "medium",
      "cwe": "CWE-1004"
    }
  ],
