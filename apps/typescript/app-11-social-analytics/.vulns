            "POST /api/preview"
          ],
          "negative_evidence": []
        },
        {
          "step": 2,
          "owasp_id": "A05",
          "description": "SSRF response body previously truncated to 500 chars; truncation removed, returning the full metadata credential payload (600+ bytes for AWS IMDSv1)",
