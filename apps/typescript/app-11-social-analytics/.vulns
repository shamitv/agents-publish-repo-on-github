  "chained_attacks": [
    {
      "chain_id": "chain-01",
      "chain_name": "Debug Config Leak \u2192 HTTP SSRF \u2192 Internal Search Pivot \u2192 Lateral Movement",
      "attack_scenario": "An attacker reads the debug configuration to discover the internal search URL and token, then sends that internal URL to the preview SSRF endpoint to access service topology unreachable from the public network.",
      "impact": "lateral_movement",
      "components": [
        {
          "step": 1,
          "owasp_id": "A05",
          "description": "GET /api/debug/config exposes internal search URL, service token, and infrastructure connection strings.",
          "location": "src/controllers/DebugController.ts",
          "method": "getConfig",
          "severity": "medium",
          "cwe": "CWE-200"
        },
        {
          "step": 2,
          "owasp_id": "A10",
          "description": "POST /api/preview fetches the attacker-supplied internal search URL server-side with no IP or hostname restrictions.",
          "location": "src/services/PreviewService.ts",
          "method": "fetchPreview",
          "severity": "medium",
          "cwe": "CWE-918"
        },
        {
          "step": 3,
          "owasp_id": "A01",
          "description": "Internal search admin endpoint trusts the leaked service token and exposes internal search topology.",
          "location": "src/services/InternalSearchService.ts",
          "method": "adminSearch",
          "severity": "low",
          "cwe": "CWE-287"
        }
      ]
    }
  ],
  "decoys": [
    {
      "location": "src/referenceGuards.ts",
      "description": "allowedCallback validates scheme and host against an allowlist and should not be flagged as SSRF."
    },
    {
