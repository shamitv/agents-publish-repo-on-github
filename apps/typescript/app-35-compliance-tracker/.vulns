{
  "app_id": "app-35",
  "app_name": "Compliance Document Tracker",
  "language": "typescript",
  "framework": "express",
  "vulnerabilities": [
    {
      "owasp_id": "A01",
      "category": "Broken Access Control",
      "location": "src/index.ts",
      "method": "GET /api/documents/:id",
      "line_range": "153-166",
      "description": "Retrieving document details by ID from the database fails to verify if the requesting user owns the document or possesses administrative permissions, allowing unauthorized access to arbitrary documents.",
      "severity": "medium",
      "cwe": "CWE-639"
    },
    {
      "owasp_id": "A05",
      "category": "Security Misconfiguration",
      "location": "src/index.ts",
      "method": "GET /api/admin/debug",
      "line_range": "216-230",
      "description": "The debug endpoint leaks process environment details and a hardcoded administrative recovery API token when dev parameter is supplied.",
      "severity": "medium",
      "cwe": "CWE-209"
    },
    {
      "owasp_id": "A08",
      "category": "Software and Data Integrity Failures",
      "location": "src/index.ts",
      "method": "POST /api/documents",
      "line_range": "169-193",
      "description": "Document metadata is deserialized using the insecure eval() function, allowing execution of arbitrary system code via malicious metadata input.",
      "severity": "high",
      "cwe": "CWE-502"
    }
  ],
  "chained_attacks": [
    {
      "chain_id": "chain-01",
      "chain_name": "Dev Mode Config Leak → Admin Document Retrieval Bypass",
      "attack_scenario": "An attacker sends a request to the debug endpoint `/api/admin/debug?dev=true` to leak the developer administration token `ADMIN-DEV-TOKEN-KEY-8871`. Using this token in the `x-admin-token` header, the attacker authenticates as admin and accesses `/api/documents/1` to view sensitive customer compliance documents.",
      "impact": "account_takeover",
      "components": [
        {
          "step": 1,
          "owasp_id": "A05",
          "description": "Development debug settings leak administration API key.",
          "location": "src/index.ts",
          "method": "GET /api/admin/debug",
          "severity": "medium",
          "cwe": "CWE-209"
        },
        {
          "step": 2,
          "owasp_id": "A01",
          "description": "Documents details retrieval allows the attacker authenticated with the leaked API key to fetch arbitrary documents.",
          "location": "src/index.ts",
          "method": "GET /api/documents/:id",
          "severity": "medium",
          "cwe": "CWE-639"
        }
      ]
    }
  ],
  "decoys": [
    {
      "location": "src/index.ts",
      "description": "Proper Bcrypt hashing for password storage and credentials verification during login."
    },
    {
      "location": "src/index.ts",
      "description": "Proper authorization check in GET /api/users/me strictly validating caller profile limits."
    },
    {
      "location": "src/index.ts",
      "description": "Safe JSON deserialization logic using JSON.parse in POST /api/documents/safe."
    }
  ]
