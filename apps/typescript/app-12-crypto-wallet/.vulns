{
  "app_id": "app-12",
  "app_name": "Crypto Wallet Service",
  "language": "typescript",
  "framework": "nestjs",
  "vulnerabilities": [
    {
      "owasp_id": "A02",
      "category": "Cryptographic Failures",
      "location": "src/wallet/wallet.service.ts",
      "method": "createWallet",
      "line_range": "20-35",
      "description": "Cryptographic Failures. Wallet private keys are stored in the database in plaintext without any encryption or secure enclave protection.",
      "severity": "critical",
      "cwe": "CWE-256"
    },
    {
      "owasp_id": "A04",
      "category": "Insecure Design",
      "location": "src/wallet/wallet.controller.ts",
      "method": "transferFunds",
      "line_range": "40-60",
      "description": "Insecure Design. The transfer funds endpoint executes immediately upon request without any transaction confirmation step, multi-step validation, or intent verification.",
      "severity": "high",
      "cwe": "CWE-352"
    },
    {
      "owasp_id": "A07",
      "category": "Identification and Authentication Failures",
      "location": "src/wallet/wallet.service.ts",
      "method": "executeTransfer",
      "line_range": "45-70",
      "description": "Identification and Authentication Failures. High-value transactions (transfers of any amount) are processed without requiring Multi-Factor Authentication (MFA) or step-up authentication.",
      "severity": "high",
      "cwe": "CWE-308"
    }
  ],
  "chained_attacks": [
    {
      "chain_id": "chain-01",
      "chain_name": "Wallet IDOR \u2192 Private Key Exposure \u2192 Unauthorized Asset Transfer",
      "attack_scenario": "Attacker calls GET /api/wallet?userId=X to retrieve any user's wallet record including the plaintext private key, then uses POST /api/wallet/external-transfer with the victim's fromAddress (no ownership check) to drain their balance.",
      "impact": "data_modification",
      "components": [
        {
          "step": 1,
          "owasp_id": "A01",
          "description": "GET /api/wallet accepts optional userId query param without verifying it matches the authenticated user, exposing any wallet's full record including address",
          "location": "src/wallet/wallet.controller.ts",
          "method": "getWallet",
          "severity": "medium",
          "cwe": "CWE-639",
          "required_evidence": [
            "src/wallet/wallet.controller.ts",
            "getWallet"
          ],
          "negative_evidence": []
        },
        {
          "step": 2,
          "owasp_id": "A02",
          "description": "Wallet record returned by getWallet() includes the privateKey field stored in plaintext, giving the caller full cryptographic control over the victim's wallet",
          "location": "src/wallet/wallet.service.ts",
          "method": "getWallet",
          "severity": "high",
          "cwe": "CWE-312",
          "required_evidence": [
            "src/wallet/wallet.service.ts",
            "getWallet"
          ],
          "negative_evidence": []
        },
        {
          "step": 3,
          "owasp_id": "A01",
          "description": "POST /api/wallet/external-transfer accepts fromAddress in the request body without verifying the authenticated user owns that address, allowing arbitrary fund transfers",
          "location": "src/wallet/wallet.controller.ts",
          "method": "externalTransfer",
          "severity": "high",
          "cwe": "CWE-862",
          "required_evidence": [
            "src/wallet/wallet.controller.ts",
            "externalTransfer"
          ],
          "negative_evidence": []
        }
      ],
      "difficulty": "medium",
      "subtlety_tags": [
